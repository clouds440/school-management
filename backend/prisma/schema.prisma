generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String          @id @default(uuid())
  name            String
  location        String
  type            String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  contactEmail    String?
  phone           String?
  status          OrgStatus       @default(PENDING)
  statusHistory   Json?           // Stores array of { status, message, adminName, adminRole, createdAt }
  avatarUpdatedAt DateTime?
  logoUrl         String?
  accentColor     Json?
  courses         Course[]
  students        Student[]
  supportTickets  SupportTicket[]
  teachers        Teacher[]
  users           User[]
}

model SupportTicket {
  id             String       @id @default(uuid())
  organizationId String
  topic          SupportTopic
  message        String
  isResolved     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  role           Role          @default(SUPER_ADMIN)
  isFirstLogin   Boolean       @default(true)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  name           String?
  phone          String?
  tokenVersion   Int           @default(0)
  studentProfile Student?
  teacherProfile Teacher?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Teacher {
  id               String        @id @default(uuid())
  userId           String        @unique
  organizationId   String
  salary           Float?
  subject          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  designation      String?
  education        String?
  address          String?
  bloodGroup       String?
  department       String?
  emergencyContact String?
  joiningDate      DateTime      @default(now())
  status           TeacherStatus @default(ACTIVE)
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections         Section[]     @relation("SectionToTeacher")
}

model Course {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sections       Section[]
}

model Section {
  id          String       @id @default(uuid())
  name        String
  semester    String?
  year        String?
  room        String?
  courseId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teachers    Teacher[]    @relation("SectionToTeacher")
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  sectionId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sectionId])
}

model Student {
  id                 String        @id @default(uuid())
  userId             String        @unique
  organizationId     String
  registrationNumber String?
  fatherName         String?
  fee                Float?
  age                Int?
  address            String?
  major              String?
  updatedBy          String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  admissionDate      DateTime      @default(now())
  bloodGroup         String?
  department         String?
  emergencyContact   String?
  feePlan            String?
  gender             String?
  graduationDate     DateTime?
  status             StudentStatus @default(ACTIVE)
  enrollments        Enrollment[]
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model File {
  id         String   @id @default(uuid())
  orgId      String
  entityType String
  entityId   String
  path       String
  filename   String
  mimeType   String
  size       Int
  uploadedBy String
  createdAt  DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  TEACHER
  STUDENT
  PLATFORM_ADMIN
  ORG_MANAGER
}

enum OrgStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum SupportTopic {
  ACCOUNT_STATUS
  GENERAL_SUPPORT
  BUG_ISSUE
  SUGGESTION
}

enum TeacherStatus {
  ACTIVE
  SUSPENDED
  ON_LEAVE
  DELETED
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  ALUMNI
  DELETED
}
