generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String         @id @default(uuid())
  name            String
  location        String
  type            String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  contactEmail    String
  phone           String?
  status          OrgStatus      @default(PENDING)
  statusHistory   Json? // Stores array of { status, message, adminName, adminRole, createdAt }
  avatarUpdatedAt DateTime?
  logoUrl         String?
  accentColor     Json?
  courses         Course[]
  students        Student[]
  teachers        Teacher[]
  users           User[]
  assessments     Assessment[]
  mails           Mail[]
  parentOrgId     String?
  parentOrg       Organization?  @relation("ParentChildOrg", fields: [parentOrgId], references: [id])
  subOrgs         Organization[] @relation("ParentChildOrg")
  chats           Chat[]
  announcements   Announcement[]

  @@index([status])
  @@index([type])
}

model User {
  id                    String             @id @default(uuid())
  email                 String             @unique
  password              String
  role                  Role               @default(SUPER_ADMIN)
  isFirstLogin          Boolean            @default(true)
  organizationId        String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  name                  String?
  phone                 String?
  themeMode             ThemeMode          @default(SYSTEM)
  avatarUrl             String?
  avatarUpdatedAt       DateTime?
  studentProfile        Student?
  teacherProfile        Teacher?
  organization          Organization?      @relation(fields: [organizationId], references: [id])
  sessions             Session[]
  createdMails         Mail[]         @relation("CreatedMails")
  assignedMails        Mail[]         @relation("AssignedMails")
  participatingMails   Mail[]         @relation("MailParticipants")
  sentMessages         MailMessage[]  @relation("SentMessages")
  performedActions     MailActionLog[] @relation("PerformedActions")
  viewedMails          MailUserView[]

  createdChats          Chat[]             @relation("CreatedChats")
  chatParticipations    ChatParticipant[]  @relation("ChatParticipations")
  sentChatMessages      ChatMessage[]      @relation("SentChatMessages")
  deletedChatMessages   ChatMessage[]      @relation("DeletedChatMessages")
  userNotifications     Notification[]     @relation("UserNotifications")
  createdAnnouncements  Announcement[]     @relation("CreatedAnnouncements")

  @@index([organizationId])
  @@index([role])
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  deviceId    String
  deviceName  String?  // e.g., "Chrome on Windows", "Safari on iPhone"
  deviceType  String?  // e.g., "desktop", "mobile", "tablet"
  browser     String?  // e.g., "Chrome", "Safari"
  os          String?  // e.g., "Windows", "iOS"
  location    String?  // e.g., "New York, USA"
  ip          String?  // IP address
  token       String   // JWT token for this session
  isActive    Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@index([isActive])
}

model Teacher {
  id               String        @id @default(uuid())
  userId           String        @unique
  organizationId   String
  salary           Float         @default(0.0)
  subject          String        @default("Unassigned")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  designation      String        @default("Unassigned")
  education        String        @default("Unassigned")
  address          String?
  bloodGroup       String?
  department       String?
  emergencyContact String?
  joiningDate      DateTime      @default(now())
  status           TeacherStatus @default(ACTIVE)
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections         Section[]     @relation("SectionToTeacher")

  @@index([organizationId])
}

model Course {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedBy      String?
  sections       Section[]
  assessments    Assessment[]

  @@index([organizationId])
}

model Section {
  id          String       @id @default(uuid())
  name        String
  semester    String?
  year        String?
  room        String?
  courseId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teachers    Teacher[]    @relation("SectionToTeacher")
  schedules          SectionSchedule[]
  attendanceSessions AttendanceSession[]
  assessments        Assessment[]

  @@index([courseId])
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  sectionId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sectionId])
  @@index([sectionId])
  @@index([studentId])
}

model Student {
  id                 String        @id @default(uuid())
  userId             String        @unique
  organizationId     String
  registrationNumber String        @default("TEMP_ID")
  rollNumber         String        @default("TEMP_ROLL")
  fatherName         String?
  fee                Float         @default(0.0)
  age                Int?
  address            String?
  major              String        @default("Unassigned")
  updatedBy          String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  admissionDate      DateTime      @default(now())
  bloodGroup         String?
  department         String?
  emergencyContact   String?
  feePlan            String        @default("Unassigned")
  gender             String        @default("Unassigned")
  graduationDate     DateTime?
  status             StudentStatus @default(ACTIVE)
  enrollments        Enrollment[]
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  grades             Grade[]
  submissions        Submission[]
  attendanceRecords  AttendanceRecord[]

  @@index([organizationId])
}

model Assessment {
  id               String         @id @default(uuid())
  sectionId        String
  courseId         String
  title            String
  type             AssessmentType
  totalMarks       Float
  weightage        Float // percentage 0-100
  dueDate          DateTime?
  allowSubmissions Boolean        @default(true)
  externalLink     String?
  isVideoLink      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  section          Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId   String
  grades           Grade[]
  submissions      Submission[]

  @@index([sectionId])
  @@index([courseId])
  @@index([dueDate])
}

model Grade {
  id            String      @id @default(uuid())
  assessmentId  String
  studentId     String
  marksObtained Float
  feedback      String?
  status        GradeStatus @default(DRAFT)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  updatedBy     String? // userId
  assessment    Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId])
  @@index([studentId])
}

model Submission {
  id           String     @id @default(uuid())
  assessmentId String
  studentId    String
  fileUrl      String?
  submittedAt  DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ─── Mail System ────────────────────────────────────────────────────────────────

model Mail {
  id       String        @id @default(uuid())
  subject  String
  category String // flexible string, not rigid enum
  priority String        @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  status   MailStatus @default(OPEN)

  // Creator context
  creatorId   String
  creatorRole String
  creator     User   @relation("CreatedMails", fields: [creatorId], references: [id])

  // Organization context (nullable for platform-level mails)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Targeting (who should handle it)
  targetRole String? // e.g. "SUPER_ADMIN", "PLATFORM_ADMIN"
  assigneeId String?
  assignee   User?   @relation("AssignedMails", fields: [assigneeId], references: [id])
  assignees  User[]  @relation("MailParticipants")

  // Extensibility
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages   MailMessage[]
  actionLogs MailActionLog[]
  userViews  MailUserView[]

  @@index([creatorId])
  @@index([organizationId])
  @@index([status])
  @@index([assigneeId])
}

model MailUserView {
  userId       String
  mailId       String
  lastViewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mail Mail @relation(fields: [mailId], references: [id], onDelete: Cascade)

  @@id([userId, mailId])
}

model MailMessage {
  id     String @id @default(uuid())
  mailId String
  senderId String
  content  String // markdown supported

  mail   Mail @relation(fields: [mailId], references: [id], onDelete: Cascade)
  sender User @relation("SentMessages", fields: [senderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Files linked via existing File model (entityType: "MAIL_MESSAGE", entityId: message.id)

  @@index([mailId])
  @@index([senderId])
}

model MailActionLog {
  id          String  @id @default(uuid())
  mailId      String
  performedBy String
  action      String // "CREATED", "STATUS_CHANGED", "ASSIGNED", "MESSAGE_SENT", etc.
  details     Json? // e.g. { from: "OPEN", to: "IN_PROGRESS" }
  note        String?

  mail      Mail @relation(fields: [mailId], references: [id], onDelete: Cascade)
  performer User @relation("PerformedActions", fields: [performedBy], references: [id])

  createdAt DateTime @default(now())

  @@index([mailId])
}

// ────────────────────────────────────────────────────────────────────────────────

model File {
  id         String   @id @default(uuid())
  orgId      String
  entityType String
  entityId   String
  path       String
  publicId   String?
  filename   String
  mimeType   String
  size       Int
  uploadedBy String
  createdAt  DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  TEACHER
  STUDENT
  PLATFORM_ADMIN
  ORG_MANAGER
}

enum OrgStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum MailStatus {
  OPEN
  IN_PROGRESS
  AWAITING_RESPONSE
  RESOLVED
  CLOSED
  NO_REPLY
}

enum TeacherStatus {
  ACTIVE
  SUSPENDED
  ON_LEAVE
  DELETED
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  ALUMNI
  DELETED
}

enum AssessmentType {
  ASSIGNMENT
  QUIZ
  MIDTERM
  FINAL
  PROJECT
}

enum GradeStatus {
  DRAFT
  PUBLISHED
  FINALIZED
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

// ─── CHAT SYSTEM ────────────────────────────────────────────────────────────

enum ChatType {
  DIRECT
  GROUP
}

enum ChatParticipantRole {
  ADMIN
  MOD
  MEMBER
}

enum ChatMessageType {
  TEXT
  SYSTEM
}

model Chat {
  id             String   @id @default(uuid())
  type           ChatType
  name           String? // For group chats
  avatarUrl      String? // Group picture URL
  avatarUpdatedAt DateTime?
  organizationId String? // Null if platform-level chat
  creatorId      String // User who created the group
  readOnly       Boolean  @default(false) // If true, only ADMIN and MOD can send messages

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User              @relation("CreatedChats", fields: [creatorId], references: [id])
  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([organizationId])
}

model ChatParticipant {
  id                String                  @id @default(uuid())
  chatId            String
  userId            String
  role              ChatParticipantRole     @default(MEMBER)
  isActive          Boolean                  @default(true)
  lastReadMessageId String?
  joinedAt          DateTime                 @default(now())
  membershipHistory ChatMembershipHistory[]

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation("ChatParticipations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model ChatMembershipHistory {
  id                String   @id @default(uuid())
  chatParticipantId String
  activatedAt       DateTime @default(now())
  deactivatedAt     DateTime?

  participant ChatParticipant @relation(fields: [chatParticipantId], references: [id], onDelete: Cascade)

  @@index([chatParticipantId])
}


model ChatMessage {
  id             String          @id @default(uuid())
  chatId         String
  senderId       String
  organizationId String?
  content        String // markdown supported
  type           ChatMessageType @default(TEXT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  deletedById    String?

  chat        Chat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User  @relation("SentChatMessages", fields: [senderId], references: [id])
  deletedBy   User? @relation("DeletedChatMessages", fields: [deletedById], references: [id])

  replyToId String?
  replyTo   ChatMessage?  @relation("ChatReply", fields: [replyToId], references: [id])
  replies   ChatMessage[] @relation("ChatReply")

  @@index([chatId, createdAt])
  @@index([senderId])
}

// ─── NOTIFICATION SYSTEM ─────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String?
  actionUrl String?
  type      String?
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ─── ANNOUNCEMENT SYSTEM ─────────────────────────────────────────────────────
enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TargetType {
  GLOBAL
  ORG
  ROLE
  SECTION
}

model Announcement {
  id             String     @id @default(uuid())
  title          String
  body           String // Markdown
  targetType     TargetType
  targetId       String? // e.g. orgId, role name, or sectionId
  actionUrl      String?
  priority       AnnouncementPriority @default(NORMAL)
  creatorId      String
  organizationId String? // Scope to org if applicable
  createdAt      DateTime   @default(now())

  creator      User          @relation("CreatedAnnouncements", fields: [creatorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([targetType, targetId])
}

// ─── TIMETABLE & ATTENDANCE SYSTEM ──────────────────────────────────────────

model SectionSchedule {
  id        String   @id @default(uuid())
  sectionId String

  day       Int      // 0 = Sunday, 1 = Monday ... 6 = Saturday
  startTime String   // "09:00"
  endTime   String   // "10:00"

  room      String?  // optional override

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([day])

  attendanceSessions AttendanceSession[]
}

model AttendanceSession {
  id        String   @id @default(uuid())
  sectionId String
  scheduleId String?
  isAdhoc     Boolean  @default(false)
  date       DateTime
  startTime  String?
  endTime    String?

  createdAt DateTime @default(now())

  section  Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schedule SectionSchedule? @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  records  AttendanceRecord[]

  @@unique([scheduleId, date])
  @@index([sectionId])
  @@index([scheduleId])
  @@index([date])
}

model AttendanceRecord {
  id         String   @id @default(uuid())
  sessionId  String
  studentId  String
  status     AttendanceStatus

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}
